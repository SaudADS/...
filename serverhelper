local ServerStorage = game:GetService("ServerStorage")
local Players = game:GetService("Players")

-- The name of your item
local itemName = "Building Tools"
local item = ServerStorage:FindFirstChild(itemName)

-- Function to give the tool to a player
local function giveTool(player)
	if item then
		local toolClone = item:Clone()
		toolClone.Parent = player.Backpack
	else
		warn(itemName .. " not found in ServerStorage!")
	end
end

-- 1. Give to players already in the server
for _, player in ipairs(Players:GetPlayers()) do
	giveTool(player)
end

-- 2. Give to players when they join the game
Players.PlayerAdded:Connect(function(player)
	-- We wait for the Character to load to ensure the Backpack is ready
	player.CharacterAdded:Connect(function()
		giveTool(player)
	end)
end)
