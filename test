-- ServerScriptService > Script
-- THE COLONY - FULL NUKE SCRIPT

local THE_COLONY_ASSET_ID = 118304815646943
local THE_COLONY_SOUND = "rbxassetid://76787687695950"

local hint = Instance.new("Hint")
hint.Text = "THE GREAT PRARIE BREACH"
hint.Parent = workspace

-- =============================
-- RESOLVE REAL IMAGE CONTENT ID
-- =============================
local InsertService = game:GetService("InsertService")
local Players = game:GetService("Players")
local THE_COLONY_IMAGE

local success, model = pcall(function()
	return InsertService:LoadAsset(THE_COLONY_ASSET_ID)
end)

if success and model then
	for _, child in ipairs(model:GetDescendants()) do
		if child:IsA("Decal") then
			THE_COLONY_IMAGE = child.Texture
			break
		elseif child:IsA("ImageLabel") or child:IsA("ImageButton") then
			THE_COLONY_IMAGE = child.Image
			break
		end
	end
	model:Destroy()
end

if not THE_COLONY_IMAGE or THE_COLONY_IMAGE == "" then
	THE_COLONY_IMAGE = "rbxassetid://" .. THE_COLONY_ASSET_ID
end

-- =============================
-- BLAST SOUND EVERYWHERE
-- =============================
local function blastSound(parent)
	local sound = Instance.new("Sound")
	sound.SoundId = THE_COLONY_SOUND
	sound.Volume = 10
	sound.Looped = true
	sound.RollOffMode = Enum.RollOffMode.Linear
	sound.RollOffMinDistance = 9999999
	sound.RollOffMaxDistance = 10000000
	sound.Parent = parent
	sound:Play()
	return sound
end

blastSound(workspace)

local globalSound = Instance.new("Sound")
globalSound.SoundId = THE_COLONY_SOUND
globalSound.Volume = 10
globalSound.Looped = true
globalSound.Parent = game:GetService("SoundService")
globalSound:Play()

local function blastOnCharacter(character)
	task.wait(1)
	local root = character:FindFirstChild("HumanoidRootPart")
	if root then
		blastSound(root)
	end
end

-- =============================
-- SERVICES TO SCAN
-- =============================
local services = {
	workspace,
	game:GetService("Lighting"),
	game:GetService("ReplicatedStorage"),
	game:GetService("ReplicatedFirst"),
	game:GetService("StarterGui"),
	game:GetService("StarterPack"),
	game:GetService("StarterPlayer"),
	game:GetService("SoundService"),
}

-- =============================
-- NUKE FUNCTION
-- =============================
local function nuke(instance)
	if instance:IsA("BasePart") then
		for _, child in ipairs(instance:GetChildren()) do
			if child:IsA("Decal") or child:IsA("Texture") then
				child:Destroy()
			end
		end

		for _, face in ipairs(Enum.NormalId:GetEnumItems()) do
			local decal = Instance.new("Decal")
			decal.Face = face
			decal.Texture = THE_COLONY_IMAGE
			decal.Parent = instance
		end
	end

	if instance:IsA("MeshPart") then
		for _, child in ipairs(instance:GetChildren()) do
			if child:IsA("SurfaceAppearance") then
				child:Destroy()
			end
		end
		local sa = Instance.new("SurfaceAppearance")
		sa.ColorMap = THE_COLONY_IMAGE
		sa.Parent = instance
	end

	if instance:IsA("SpecialMesh") or instance:IsA("FileMesh") then
		pcall(function() instance.TextureId = THE_COLONY_IMAGE end)
	end

	if instance:IsA("Decal") or instance:IsA("Texture") then
		pcall(function() instance.Texture = THE_COLONY_IMAGE end)
	end

	if instance:IsA("ImageLabel") or instance:IsA("ImageButton") then
		pcall(function() instance.Image = THE_COLONY_IMAGE end)
	end

	if instance:IsA("ParticleEmitter") then
		pcall(function() instance.Texture = THE_COLONY_IMAGE end)
	end

	if instance:IsA("Beam") then
		pcall(function() instance.Texture = THE_COLONY_IMAGE end)
	end

	if instance:IsA("Trail") then
		pcall(function() instance.Texture = THE_COLONY_IMAGE end)
	end

	if instance:IsA("Sky") then
		instance.SkyboxBk = THE_COLONY_IMAGE
		instance.SkyboxDn = THE_COLONY_IMAGE
		instance.SkyboxFt = THE_COLONY_IMAGE
		instance.SkyboxLf = THE_COLONY_IMAGE
		instance.SkyboxRt = THE_COLONY_IMAGE
		instance.SkyboxUp = THE_COLONY_IMAGE
	end

	if instance:IsA("Shirt") then
		pcall(function() instance.ShirtTemplate = THE_COLONY_IMAGE end)
	end

	if instance:IsA("Pants") then
		pcall(function() instance.PantsTemplate = THE_COLONY_IMAGE end)
	end

	if instance:IsA("ShirtGraphic") then
		pcall(function() instance.Graphic = THE_COLONY_IMAGE end)
	end

	if instance:IsA("Decal") and instance.Name == "face" then
		pcall(function() instance.Texture = THE_COLONY_IMAGE end)
	end

	if instance:IsA("Terrain") then
		pcall(function()
			for _, material in ipairs(Enum.Material:GetEnumItems()) do
				pcall(function()
					instance:SetMaterialColor(material, Color3.new(1, 0, 1))
				end)
			end
		end)
	end
end

-- =============================
-- PHASE 1: NUKE ALL SERVICES
-- =============================
for _, service in ipairs(services) do
	pcall(function()
		for _, desc in ipairs(service:GetDescendants()) do
			pcall(function() nuke(desc) end)
		end
	end)
end

-- =============================
-- PHASE 2: LISTEN FOR NEW STUFF
-- =============================
for _, service in ipairs(services) do
	pcall(function()
		service.DescendantAdded:Connect(function(desc)
			task.defer(function()
				pcall(function() nuke(desc) end)
			end)
		end)
	end)
end

-- =============================
-- PHASE 3: CHARACTERS
-- =============================
local function nukeCharacter(character)
	task.wait(2)
	for _, desc in ipairs(character:GetDescendants()) do
		pcall(function() nuke(desc) end)
	end
	character.DescendantAdded:Connect(function(desc)
		task.defer(function()
			pcall(function() nuke(desc) end)
		end)
	end)
	blastOnCharacter(character)
end

for _, player in ipairs(Players:GetPlayers()) do
	if player.Character then
		coroutine.wrap(nukeCharacter)(player.Character)
	end
	player.CharacterAdded:Connect(function(char)
		coroutine.wrap(nukeCharacter)(char)
	end)
end

Players.PlayerAdded:Connect(function(player)
	player.CharacterAdded:Connect(function(char)
		coroutine.wrap(nukeCharacter)(char)
	end)
end)

-- =============================
-- PHASE 4: CONTINUOUS SWEEP LOOP
-- =============================
task.spawn(function()
	while true do
		task.wait(5)
		for _, desc in ipairs(workspace:GetDescendants()) do
			pcall(function()
				if desc:IsA("BasePart") then
					local hasColony = false
					for _, child in ipairs(desc:GetChildren()) do
						if child:IsA("Decal") and child.Texture == THE_COLONY_IMAGE then
							hasColony = true
							break
						end
					end
					if not hasColony then
						nuke(desc)
					end
				end
			end)
		end
	end
end)
